datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Service {
  id           Int           @id @default(autoincrement())
  name         String
  price        Float
  duration     Int
  description  String
  active       Boolean       @default(true)
  appointments Appointment[]
}

model Appointment {
  id          Int      @id @default(autoincrement())
  clientName  String
  clientPhone String
  date        String
  time        String
  status      String   @default("confirmed")
  notes       String   @default("")
  serviceId   Int
  service     Service  @relation(fields: [serviceId], references: [id])
  createdAt   DateTime @default(now())
}

model RecurringBlock {
  id         Int    @id @default(autoincrement())
  clientName String
  dayOfWeek  Int
  time       String
  notes      String @default("")
}
