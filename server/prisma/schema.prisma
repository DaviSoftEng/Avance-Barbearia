datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Service {
  id           Int           @id @default(autoincrement())
  name         String
  price        Float
  duration     Int
  description  String
  active       Boolean       @default(true)
  appointments Appointment[]
}

// status: confirmed | completed | no_show | cancelled
model Appointment {
  id          Int      @id @default(autoincrement())
  clientName  String
  clientPhone String
  date        String
  time        String
  status      String   @default("confirmed")
  notes       String   @default("")
  price       Float    @default(0)
  serviceId   Int
  service     Service  @relation(fields: [serviceId], references: [id])
  createdAt   DateTime @default(now())
}

model RecurringBlock {
  id         Int    @id @default(autoincrement())
  clientName String
  dayOfWeek  Int
  time       String
  notes      String @default("")
}

// Horário de funcionamento por dia da semana (0=Dom, 1=Seg, ..., 6=Sab)
model BusinessHours {
  id        Int     @id @default(autoincrement())
  dayOfWeek Int     @unique
  isOpen    Boolean @default(true)
  openTime  String  @default("09:00")
  closeTime String  @default("19:00")
}

// Bloqueio de dia específico (férias, feriado, folga)
model DayBlock {
  id        Int     @id @default(autoincrement())
  date      String
  reason    String  @default("")
  startTime String?
  endTime   String?
}
